# HtmlGraph policy
# Track canonical declarative project state under .htmlgraph/:
# - work-item HTML/YAML content
# - project config/metadata
# - archive HTML when intentionally retained as part of repo history
#
# Ignore only derived storage/index artifacts and runtime telemetry.

# HtmlGraph derived database/index/cache artifacts
.htmlgraph/*.db*
.htmlgraph/*.sqlite*
.htmlgraph/archive-index/
*.bloom

# HtmlGraph runtime/session telemetry
.htmlgraph/events/
.htmlgraph/sessions/
.htmlgraph/logs/
.htmlgraph/**/*.jsonl
.htmlgraph/**/*.log
.htmlgraph/.active-session
.htmlgraph/.launch-mode
.htmlgraph/.session-warning-state.json
.htmlgraph/parent-activity.json
.htmlgraph/.error-spikes.json
.htmlgraph/active-auto-spikes.json
.htmlgraph/drift-queue.json

# HtmlGraph obsolete/generated analytics artifacts from older builds
.htmlgraph/cigs/
.htmlgraph/insights/
.htmlgraph/metrics/
.htmlgraph/orchestrator-mode.json

# HtmlGraph invalid nested state
.htmlgraph/.htmlgraph/

# HtmlGraph tracked canonical content should override broad global ignores
!.htmlgraph/**/*.html
!.htmlgraph/**/*.yaml
!.htmlgraph/**/*.yml
!.htmlgraph/**/*.css

.env

# MkDocs build output
site/

# pdoc generated documentation
docs/api-pdoc/
docs/api/*.html
docs/api/*.js

.contextune/
.claude/settings.local.json

# Prevent root clutter from accumulating
# Screenshots and temp images
*.png
# One-off scratch/test files
*.txt
!requirements*.txt
# Coverage artifacts
coverage.json
# Session state
.session-warning-state.json
# Marimo sessions
__marimo__/
# UV cache
.uv-cache/
# Mypy cache
.mypy_cache/

# Build artifacts
_build/
archive/
packages/go-plugin/hooks/bin/
hooks/bin/
plugin/hooks/bin/htmlgraph

# Notebook files copied at build time from prototypes/ (do not commit)
internal/notebook/files/
dist/
_build/tailwind-*
chrome/*.zip
