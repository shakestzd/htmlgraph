#!/bin/sh
# Pre-commit hook: Go quality gates
#
# Install: htmlgraph install-hooks
#          (sets core.hooksPath = .githooks)

set -e

REPO_ROOT="$(git rev-parse --show-toplevel)"
echo "Running pre-commit checks..."

# Go source is at the repo root (go.mod, cmd/, internal/)
if git diff --cached --name-only | grep -q '\.go$' || [ -f "$REPO_ROOT/go.mod" ]; then
    if [ ! -f "$REPO_ROOT/go.mod" ]; then
        echo "  Warning: no go.mod found at repo root, skipping Go checks."
    else
        echo "  -> go build..."
        if ! (cd "$REPO_ROOT" && go build ./...) ; then
            echo "FAIL: go build failed. Fix compilation errors before committing."
            exit 1
        fi

        echo "  -> go vet..."
        if ! (cd "$REPO_ROOT" && go vet ./...) ; then
            echo "FAIL: go vet failed. Fix issues before committing."
            exit 1
        fi

        echo "  -> go test..."
        # Scope tests to packages containing staged Go files + their direct
        # reverse dependencies inside this module. The full `go test ./...`
        # suite runs ~5-8 min in ARM64 Codespaces and routinely stalls
        # parallel commits (bug-85675e04). CI still runs the full suite.
        #
        # Set HTMLGRAPH_HOOK_FULL_TESTS=1 to force the legacy full run.
        # Unset GIT_DIR/GIT_INDEX_FILE so tests that create real git repos
        # (e.g. TestBranchForFilePath) are not polluted by the pre-commit env.
        if [ -n "${HTMLGRAPH_HOOK_FULL_TESTS:-}" ]; then
            TEST_TARGETS="./..."
        else
            STAGED_PKGS=$(git diff --cached --name-only --diff-filter=ACMR -- '*.go' \
                | xargs -I{} dirname "$REPO_ROOT/{}" 2>/dev/null \
                | sort -u \
                | sed "s|^$REPO_ROOT|.|" \
                | sed 's|^\.$|./|' \
                | sed 's|$|/...|')
            if [ -z "$STAGED_PKGS" ]; then
                echo "     (no staged .go files — skipping test run)"
                STAGED_PKGS=""
            fi
            TEST_TARGETS="$STAGED_PKGS"
        fi
        if [ -n "$TEST_TARGETS" ]; then
            if ! (cd "$REPO_ROOT" && env -u GIT_DIR -u GIT_INDEX_FILE -u GIT_WORK_TREE go test $TEST_TARGETS) ; then
                echo "FAIL: go test failed. Fix failing tests before committing."
                echo "      (scoped to staged packages; run 'go test ./...' locally or set HTMLGRAPH_HOOK_FULL_TESTS=1 for the full suite.)"
                exit 1
            fi
        fi
    fi
fi

# Reject stray htmlgraph binary at repo root (use `htmlgraph build` instead)
if git diff --cached --name-only | grep -q '^htmlgraph$'; then
    echo "FAIL: A binary named 'htmlgraph' is staged at the repo root."
    echo "      Run 'htmlgraph build' instead — it outputs to plugin/hooks/bin/htmlgraph."
    echo "      Unstage it with: git reset HEAD htmlgraph"
    exit 1
fi

# Scan staged .htmlgraph/ and .claude/ artifacts for host-local absolute paths
if git diff --cached --name-only | grep -qE '^(\.htmlgraph/|\.claude/)'; then
    echo "  -> check-host-paths (staged)..."
    if ! "$REPO_ROOT/scripts/check-host-paths.sh" --staged ; then
        echo "FAIL: host-local paths found in staged files. See output above."
        exit 1
    fi
fi

echo "All pre-commit checks passed!"
