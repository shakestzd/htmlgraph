{
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "comment": "Track user query to database",
            "command": "HTMLGRAPH_HOOK_TYPE=UserPromptSubmit uv run \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/track-event.py\""
          },
          {
            "type": "command",
            "comment": "CIGS analysis and workflow guidance",
            "command": "uv run \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/user-prompt-submit.py\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "HTMLGRAPH_HOOK_TYPE=Stop uv run \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/track-event.py\""
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "uv run \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/session-end.py\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "comment": "Route Task() calls to spawner agents (gemini, codex, copilot)",
            "command": "uv run \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/pretooluse-integrator.py\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "uv run \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/posttooluse-integrator.py\""
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "comment": "Map agent_id to task_delegation events for correct parent attribution",
            "command": "uv run \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/subagent-start.py\""
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "uv run \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/subagent-stop.py\""
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "HTMLGRAPH_HOOK_TYPE=TeammateIdle uv run \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/track-event.py\""
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "HTMLGRAPH_HOOK_TYPE=TaskCompleted uv run \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/track-event.py\""
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "comment": "Track tool crashes and exceptions",
            "command": "uv run \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/posttooluse-failure.py\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "comment": "Record conversation compaction events",
            "command": "uv run \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/pre-compact.py\""
          }
        ]
      }
    ],
    "InstructionsLoaded": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "comment": "Record custom instructions loaded",
            "command": "uv run \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/instructions-loaded.py\""
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "comment": "Track permission requests",
            "command": "uv run \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/permission-request.py\""
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "uv run \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/session-start.py\""
          }
        ]
      },
      {
        "matcher": "resume",
        "hooks": [
          {
            "type": "command",
            "comment": "Record session resume events",
            "command": "uv run \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/session-resume.py\""
          }
        ]
      }
    ]
  }
}
