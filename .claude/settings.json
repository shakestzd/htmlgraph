{
  "permissions": {
    "allow": [
      "Write(//workspaces/htmlgraph/**)",
      "Edit(//workspaces/htmlgraph/**)",
      "NotebookEdit(//workspaces/htmlgraph/**)",
      "Bash(cd packages/go*)",
      "Bash(go build:*)",
      "Bash(go test:*)",
      "Bash(go vet:*)"
    ],
    "deny": [
      "Write(//workspaces/htmlgraph/.htmlgraph/**)",
      "Edit(//workspaces/htmlgraph/.htmlgraph/**)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "/home/vscode/.claude/omp-claude-wrapper.sh",
    "padding": 0
  },
  "plansDirectory": ".htmlgraph/plans/",
  "enabledPlugins": {},
  "claudeMdExcludes": ["AGENTS.md"]
}
